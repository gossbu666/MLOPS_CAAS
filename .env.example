# ============================================================
# CAAS — Required Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real keys.
# ============================================================

# ── NASA FIRMS fire hotspots ────────────────────────────────
# Free API key: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your_map_key_here

# Optional tuning for 04_Scripts/run_firms_batched.py (defaults in code)
# FIRMS_START_YEAR=2011
# FIRMS_END_YEAR=2026
# FIRMS_BATCH_SIZE=10
# FIRMS_BATCH_PAUSE_SEC=60
# FIRMS_BATCH_RETRIES=3

# ── AWS ─────────────────────────────────────────────────────
# IAM user with S3 read/write + (optional) EC2 + (optional) SSM
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=caas-mlops-bucket

# ── EC2 / live deployment ──────────────────────────────────
# Public IP of the Terraform-provisioned instance.
# Consumed by retrain.yml deploy step + Streamlit dashboard (optional).
EC2_HOST=your-ec2-public-ip

# ── MLflow ─────────────────────────────────────────────────
# Leave empty for local file-backed mlruns/.
# Set to http://<ec2-ip>:5000 for the EC2-hosted tracking server.
MLFLOW_TRACKING_URI=

# Public URL the Streamlit dashboard links to for the MLflow UI button.
# Leave empty to hide the link.
MLFLOW_PUBLIC_URL=

# ── Dashboard → API wiring ─────────────────────────────────
# Streamlit dashboard's FastAPI URL. Default: http://api:8000 inside docker compose,
# http://localhost:8000 for bare-metal dev.
FASTAPI_URL=http://localhost:8000

# ── GitHub (drift → retrain webhook) ───────────────────────
# Only needed for local drift-check runs; GH Actions auto-injects both.
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPOSITORY=gossbu666/MLOPS_CAAS
