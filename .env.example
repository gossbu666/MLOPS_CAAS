# ============================================================
# CAAS — Required Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real keys.
# ============================================================

# NASA FIRMS API — get free key at: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your_map_key_here

# AWS Credentials — IAM user with S3 read/write + EC2 permissions
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=caas-mlops-bucket

# EC2 — public IP or DNS of your deployed instance
EC2_HOST=your-ec2-public-ip

# MLflow — leave empty for local mlruns/, or set to http://<ec2-ip>:5000
MLFLOW_TRACKING_URI=

# GitHub — for drift→retrain trigger (auto-set in Actions, only needed locally)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPOSITORY=supanut-k/caas
